{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read(**)",
      "Write(docs/**)",
      "Write(user-stories/**)",
      "Write(claude-scaffold/**)",
      "Edit(docs/**)",
      "Edit(user-stories/**)",
      "Edit(user-story-guidelines.md)",
      "Edit(*.md)",
      "Edit(*.jsx)",
      "Edit(*.html)",
      "Edit(*.css)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(pnpm:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "WebSearch",
      "WebFetch"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git reset --hard:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Read(.env)"
    ]
  },
  "env": {
    "NODE_NO_WARNINGS": "1"
  }
}
