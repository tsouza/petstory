{
  "name": "petstory-co",
  "version": "0.0.0",
  "private": true,
  "description": "petstory.co — layered agent monorepo (kernel + primitives + pet-health pack + shells)",
  "packageManager": "bun@1.3.10",
  "engines": {
    "bun": ">=1.3",
    "node": ">=22"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/packs/*"
  ],
  "scripts": {
    "build": "bun run turbo run build",
    "lint": "bun run turbo run lint",
    "test": "bun run turbo run test",
    "typecheck": "bun run turbo run typecheck",
    "eval": "bun run turbo run eval",
    "clean": "bun run turbo run clean && rm -rf node_modules",
    "format": "biome format --write .",
    "check": "biome check .",
    "knip": "knip",
    "depcruise": "depcruise --config .dependency-cruiser.json packages apps",
    "changeset": "changeset",
    "commitlint": "commitlint",
    "convex:dev": "convex dev",
    "convex:deploy": "convex deploy"
  },
  "dependencies": {
    "convex": "^1.20.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@changesets/cli": "^2.27.0",
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "dependency-cruiser": "^16.0.0",
    "knip": "^5.0.0",
    "lefthook": "^1.7.0",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
