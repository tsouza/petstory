{
  "name": "petstory-co",
  "version": "0.0.0",
  "private": true,
  "description": "petstory.co — layered agent monorepo (kernel + primitives + pet-health pack + shells)",
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "eval": "turbo run eval",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "biome format --write .",
    "check": "biome check .",
    "knip": "knip",
    "depcruise": "depcruise --config .dependency-cruiser.json packages apps",
    "changeset": "changeset",
    "commitlint": "commitlint"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@changesets/cli": "^2.27.0",
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "dependency-cruiser": "^16.0.0",
    "knip": "^5.0.0",
    "lefthook": "^1.7.0",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "pnpm": {
    "overrides": {}
  }
}
