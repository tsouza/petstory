{
  "name": "@petstory/testing",
  "version": "0.0.0",
  "private": true,
  "description": "Shared testing package — fixtures, MSW handlers, Flow DSL test harness, LLM + chat mock adapters. Consumed via workspace:* by every package's test suite.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "biome check . --max-diagnostics 0"
  },
  "dependencies": {
    "@petstory/kernel": "workspace:*"
  },
  "devDependencies": {
    "@petstory/config": "workspace:*",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
